<?xml version="1.0" encoding="UTF-8" ?>
<properties>
  <ports>
    <ros_service service_name="/AlarmBatteryLowSkill/tick" type="bt_interfaces_dummy/TickAction" event="response">
      <state_var id="battery_low_alarm" field="status" expr="0" type="int32"/>
    </ros_service>

    <ros_topic topic_name="/BatteryComponent/battery_level" type="sensor_msgs/BatteryState" event="publish">
      <state_var id="battery_level" field="percentage" type="int32" expr="100"/>
      <event_var id="battery_published"/>
    </ros_topic>

    <ros_service service_name="/CheckIfStartSkill/tick" type="bt_interfaces_dummy/TickCondition" event="response">
      <state_var id="check_start" field="status" expr="0" type="int32"/>
    </ros_service>

    <ros_service service_name="/IsAtChargingStationSkill/tick" type="bt_interfaces_dummy/TickCondition" event="response">
      <state_var id="is_at_charging_station" field="status" expr="0" type="int32"/>
    </ros_service>

    <ros_service service_name="/GoToChargingStationSkill/tick" type="bt_interfaces_dummy/TickAction" event="response">
      <state_var id="goto_charging_station" field="status" expr="0" type="int32"/>
    </ros_service>

    <ros_topic topic_name="/PeopleDetectorFilterComponent/is_followed" type="std_msgs/Bool" event="publish" target="SystemMonitorComponent">
      <event_var id="people_following_published"/>
    </ros_topic>

    <ros_service service_name="/SchedulerComponent/GetCurrentPoiForNavigation" type="scheduler_interfaces/GetCurrentPoi" event="response">
      <state_var id="poi_selected" field="poi_number" expr="0" type="int32"/>
    </ros_service>

    <ros_service service_name="/IsPoiDone0Skill/tick" type="bt_interfaces_dummy/TickCondition" event="response">
      <state_var id="poi0_completed" field="status" expr="1" type="int32"/>
    </ros_service>

    <ros_service service_name="/IsPoiDone2Skill/tick" type="bt_interfaces_dummy/TickCondition" event="response">
      <state_var id="poi2_completed" field="status" expr="1" type="int32"/>
    </ros_service>

    <ros_service service_name="/IsPoiDone4Skill/tick" type="bt_interfaces_dummy/TickCondition" event="response">
      <state_var id="poi4_completed" field="status" expr="1" type="int32"/>
    </ros_service>

    <ros_service service_name="/IsPoiDone5Skill/tick" type="bt_interfaces_dummy/TickCondition" event="response">
      <state_var id="poi5_completed" field="status" expr="1" type="int32"/>
    </ros_service>

    <ros_service service_name="/IsPoiDone8Skill/tick" type="bt_interfaces_dummy/TickCondition" event="response">
      <state_var id="poi8_completed" field="status" expr="1" type="int32"/>
    </ros_service>

    <ros_service service_name="/IsPoiDone10Skill/tick" type="bt_interfaces_dummy/TickCondition" event="response">
      <state_var id="poi10_completed" field="status" expr="1" type="int32"/>
    </ros_service>

    <ros_topic topic_name="/CheckNetworkComponent/NetworkStatus" type="std_msgs/Bool" event="publish" target="BlackboardComponent">
      <event_var id="connected_to_network"/>
    </ros_topic>

    <ros_service service_name="/ResetTourAndFlagsSkill/tick" type="bt_interfaces_dummy/TickAction" event="response">
      <event_var id="tour_complete" field="status" expr="0" type="int32"/>
      <state_var id="completed_tour" field="status" expr="0" type="int32"/>
    </ros_service>

    <ros_service service_name="/SetCurrentPoiDoneSkill/tick" type="bt_interfaces_dummy/TickAction" event="request">
      <event_var id="poi_done_set" field="status" expr="0" type="int32"/>
    </ros_service>

    <!-- <ros_service service_name="/SchedulerComponent/GetCurrentPoi" type="scheduler_interfaces/GetCurrentPoi" event="response">
      <state_var id="poi_number_from_planner" field="poi_number" expr="0" type="int32"/>
    </ros_service> -->

    <ros_service service_name="/BlackboardComponent/GetInt" type="blackboard_interfaces/GetIntBlackboard" event="response">
      <event_var id="m_value" field="value" expr="0" type="int32"/>
      <event_var id="m_result" field="is_ok" expr="false" type="bool"/>
      <event_var id="poi_number" field="poi_number" expr="-1" type="int32"/>
    </ros_service>

  </ports>

  <guarantees>
    <!-- PROP 1: noAlarmWithHighBattery -->
    <!-- Each time the battery is charged, no alarm should be triggered -->
    <!-- PROPERTY = r"historically({high_battery} -> historically( not {alarm}))" -->
    <!-- CURRENTLY UNIMPLEMENTED -->
    <!-- <property id="noAlarmWithHighBattery" pattern="absence"> -->
      <!-- <event>battery_low_alarm</event> -->
      <!-- <scope type="before" event="battery_level &lt;= 30"/> -->
    <!-- </property> -->

    <!-- PROP 2: alarmWithLowBattery -->
    <!-- If there was an alarm the there has been at least one time before an event of low battery. -->
    <!-- Moreover, if the battery is low then the alarm should be set within 5 seconds. -->
    <property id="alarmWithLowBattery1" pattern="precedence">
      <events>
        <event>battery_level &lt;= 30</event>
        <event>battery_low_alarm == 2</event>
      </events>
      <scope type="globally"/>
    </property>
    
    <!-- <property id="alarmWithLowBattery2" pattern="precedence">
      <events>
        <event>battery_level &lt;= 30 &amp;&amp; is_at_charging_station != 0</event>
        <event>battery_low_alarm == 2</event>
      </events>
      <scope type="globally"/>
    </property> -->

    <!-- PROP 3: isBatteryPublished -->
    <!-- The battery topic should be published at least each five seconds. -->
    <property id="isBatteryPublished" pattern="existence">
      <event>battery_published</event>
      <scope type="globally"/>
    </property>
    
    <!-- PROP 4: isPoiSelectionCorrect** -->
    <!-- WARN: tour_complete? -->
    <!-- If the tour is completed, the robot must arrive to the start point within a certain time. -->
    <!-- <property id="isPoiSelectionCorrect" expr="H !({check_start == 1} S[:100] {tour_complete})"/> -->
    <!-- <property id="isPoiSelectionCorrect" pattern="absence">
      <event>check_start == 1</event>
      <scope type="after" event="tour_complete"/>
    </property> -->

    <!-- PROP 5: isPeopleFollowingPublished -->
    <!-- The peopleFollowing topic must be published at least each 7 seconds. -->
    <property id="isPeopleFollowingPublished" pattern="existence">
      <event>people_following_published</event>
      <scope type="globally"/>
    </property>

    <!-- PROP 6: isCameraPublished -->
    <!-- WARN: Cannot find camera -->
    <!-- The camera topic must be published at least each 5 seconds. -->
    <!-- <property id="isCameraPublished" expr="H ((P[50:] true) -> P[:50] { camera_published })"/> -->

    <!-- PROP 7: notCriticalBattery -->
    <!-- WARN: Cannot find critical_battery -->
    <!-- It must never happens that the battery level becomes critical. -->
    <property id="notCriticalBattery1" pattern="universality">
      <event>battery_level &gt; 10</event>
      <scope type="globally"/>
    </property>
    
    <!-- OR -->
    <property id="notCriticalBattery2" pattern="absence">
      <event>battery_level &lt;= 10</event>
      <scope type="globally"/>
    </property>

    <!-- PROP 8: notWheelsHWFault -->
    <!-- WARN: Cannot find weel/joint/control -->
    <!-- The wheels joints must not be in hardware fault. -->

    <!-- PROP 9: notJointsHWFault -->
    <!-- WARN: Cannot find joint/control -->
    <!-- The joints of the robot must not be in hardware fault. -->

    <!-- PROP 10 POI0: isPOICompletedInTime -->
    <!-- If a POI is completed, then it must have been set to selected before. -->
    <property id="isPOI0CompletedAfterSelection" pattern="precedence">
      <events>
        <event>poi_selected == 0</event>
        <event>poi0_completed == 0</event>
      </events>
      <scope type="globally"/>
    </property>

    <!-- Moreover, if a POI is selected then it must be completed within 10 minutes (1000 seconds). -->
    <property id="isPOI0CompletedInTime" pattern="response">
      <events>
        <event>poi_selected == 0</event>
        <event>poi0_completed == 0</event>
      </events>
      <scope type="globally"/>
      <time_interval time="1000" time_unit="s"/>
    </property>

    <!-- PROP 10 POI2: isPOICompletedInTime -->
    <!-- If a POI is completed, then it must have been set to selected before. -->
    <property id="isPOI2CompletedAfterSelection" pattern="precedence">
      <events>
        <event>poi_selected == 2</event>
        <event>poi2_completed == 0</event>
      </events>
      <scope type="globally"/>
    </property>

    <!-- Moreover, if a POI is selected then it must be completed within 10 minutes (1000 seconds). -->
    <property id="isPOI2CompletedInTime" pattern="response">
      <events>
        <event>poi_selected == 2</event>
        <event>poi2_completed == 0</event>
      </events>
      <scope type="globally"/>
      <time_interval time="1000" time_unit="s"/>
    </property>

    <!-- PROP 10 POI4: isPOICompletedInTime -->
    <!-- If a POI is completed, then it must have been set to selected before. -->
    <property id="isPOI4CompletedAfterSelection" pattern="precedence">
      <events>
        <event>poi_selected == 4</event>
        <event>poi4_completed == 0</event>
      </events>
      <scope type="globally"/>
    </property>

    <!-- Moreover, if a POI is selected then it must be completed within 10 minutes (1000 seconds). -->
    <property id="isPOI4CompletedInTime" pattern="response">
      <events>
        <event>poi_selected == 4</event>
        <event>poi4_completed == 0</event>
      </events>
      <scope type="globally"/>
      <time_interval time="1000" time_unit="s"/>
    </property>

    <!-- PROP 10 POI5: isPOICompletedInTime -->
    <!-- If a POI is completed, then it must have been set to selected before. -->
    <property id="isPOI5CompletedAfterSelection" pattern="precedence">
      <events>
        <event>poi_selected == 5</event>
        <event>poi5_completed == 0</event>
      </events>
      <scope type="globally"/>
    </property>

    <!-- Moreover, if a POI is selected then it must be completed within 10 minutes (1000 seconds). -->
    <property id="isPOI5CompletedInTime" pattern="response">
      <events>
        <event>poi_selected == 5</event>
        <event>poi5_completed == 0</event>
      </events>
      <scope type="globally"/>
      <time_interval time="1000" time_unit="s"/>
    </property>

    <!-- PROP 10 POI8: isPOICompletedInTime -->
    <!-- If a POI is completed, then it must have been set to selected before. -->
    <property id="isPOI8CompletedAfterSelection" pattern="precedence">
      <events>
        <event>poi_selected == 8</event>
        <event>poi8_completed == 0</event>
      </events>
      <scope type="globally"/>
    </property>

    <!-- Moreover, if a POI is selected then it must be completed within 10 minutes (1000 seconds). -->
    <property id="isPOI8CompletedInTime" pattern="response">
      <events>
        <event>poi_selected == 8</event>
        <event>poi8_completed == 0</event>
      </events>
      <scope type="globally"/>
      <time_interval time="1000" time_unit="s"/>
    </property>

    <!-- PROP 10 POI10: isPOICompletedInTime -->
    <!-- If a POI is completed, then it must have been set to selected before. -->
    <property id="isPOI10CompletedAfterSelection" pattern="precedence">
      <events>
        <event>poi_selected == 10</event>
        <event>poi10_completed == 0</event>
      </events>
      <scope type="globally"/>
    </property>

    <!-- Moreover, if a POI is selected then it must be completed within 10 minutes (1000 seconds). -->
    <property id="isPOI10CompletedInTime" pattern="response">
      <events>
        <event>poi_selected == 10</event>
        <event>poi10_completed == 0</event>
      </events>
      <scope type="globally"/>
      <time_interval time="1000" time_unit="s"/>
    </property>

    <!-- PROP 11: isWellLocalized -->
    <!-- WARN: cannot find localized/acml -->
    <!-- The robot must be well localized: i.e. the covariance provided by amcl must be lower than or equal to a certain threshold. -->

    <!-- PROP 12: isMicrophonePluggedIn -->
    <!-- WARN: cannot find microphone -->
    <!-- If the microphone is plugged in then the covariance of the audio’s output, when the microphone is recording, should be greater than a certain threshold. -->

    <!-- PROP 13: isExternalPCConnected -->
    <!-- The laptop used for launching the tour should be connected. -->
    <property id="isExternalPCConnected" pattern="existence">
      <event>connected_to_network</event>
      <scope type="globally"/>
    </property>

    <!-- PROP 14: isConnectedToWeb -->
    <!-- WARN: cannot find web -->
    <!-- The laptop or R1 base should always be connected to the web. -->

    <!-- PROP 15: isArrivedAtChargingStationInTime** -->
    <!-- When the battery is low it should arrive to the charging station within a certain amount of time. -->
    <property id="isArrivedAtChargingStationInTime" pattern="response">
      <events>
        <event>battery_low_alarm == 2</event>
        <event>is_at_charging_station == 0</event>
      </events>
      <scope type="globally"/>
      <time_interval time="10" time_unit="s"/>
    </property>

  </guarantees>

</properties>
