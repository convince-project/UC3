<?xml version="1.0" encoding="UTF-8" ?>
<properties>
  <ports>
    <!-- <ros_service_handle_request name="/NotifyUserComponent/StartAlarm" target="HandleStartAlarm"/> -->
    <ros_service service_name="/NotifyUserComponent/StartAlarm" type="notify_user_interfaces/StartAlarm" event="response">
      <event_var id="battery_low_alarm"/>
    </ros_service>

    <ros_topic topic_name="/BatteryComponent/battery_level" type="sensor_msgs/BatteryState" event="publish">
      <state_var id="battery_level" field="percentage" type="int32" expr="100"/>
      <event_var id="battery_published"/>
    </ros_topic>

    <ros_service service_name="/CheckIfStartSkill/tick" type="bt_interfaces_dummy/TickCondition" event="response">
      <state_var id="check_start" field="status" expr="0" type="int32"/>
    </ros_service>

    <ros_service service_name="/IsAtChargingStationSkill/tick" type="bt_interfaces_dummy/TickCondition" event="response">
      <state_var id="is_at_charging_station" field="status" expr="1" type="int32"/>
    </ros_service>

    <ros_service service_name="/GoToChargingStationSkill/tick" type="bt_interfaces_dummy/TickAction" event="response">
      <state_var id="goto_charging_station" field="status" expr="1" type="int32"/>
    </ros_service>

    <ros_topic topic_name="/PeopleDetectorFilterComponent/is_followed" type="std_msgs/Bool" event="publish" target="SystemMonitorComponent">
      <event_var id="people_following_published"/>
    </ros_topic>

    <ros_service service_name="/SchedulerComponent/GetCurrentPoi" type="scheduler_interfaces/GetCurrentPoi" event="response">
      <state_var id="poi_selected" field="poi_number" expr="0" type="int32"/>
    </ros_service>

    <ros_service service_name="/IsPoiDone0Skill/tick" type="bt_interfaces_dummy/TickCondition" event="response">
      <state_var id="poi0_completed" field="status" expr="1" type="int32"/>
    </ros_service>

    <ros_topic topic_name="/CheckNetworkComponent/NetworkStatus" type="std_msgs/Bool" event="publish" target="BlackboardComponent">
      <event_var id="connected_to_network"/>
    </ros_topic>
  </ports>

  <guarantees>
    <!-- PROP 1: noAlarmWithHighBattery -->
    <!-- Each time the battery is charged, no alarm should be triggered -->
    <!-- PROPERTY = r"historically({high_battery} -> historically( not {alarm}))" -->
    <property id="noAlarmWithHighBattery1" pattern="universality">
      <event>! battery_low_alarm</event>
      <scope type="after" event="battery_level &gt; 30"/>
    </property>

    <!-- OR -->
    <property id="noAlarmWithHighBattery2" pattern="absence">
      <event>battery_low_alarm</event>
      <scope type="after" event="battery_level &gt; 30"/>
    </property>

    <!-- PROP 2: alarmWithLowBattery -->
    <!-- If there was an alarm the there has been at least one time before an event of low battery. -->
    <!-- Moreover, if the battery is low then the alarm should be set within 5 seconds. -->
    <property id="alarmWithLowBattery1" pattern="precedence">
      <events>
        <event>battery_level &lt;= 30</event>
        <event>battery_low_alarm</event>
      </events>
      <scope type="globally"/>
    </property>
    
    <property id="alarmWithLowBattery2" pattern="response">
      <events>
        <event>battery_level &lt;= 30</event>
        <event>battery_low_alarm</event>
      </events>
      <scope type="globally"/>
      <time_interval time="5" time_unit="s"/>
    </property>

    <!-- PROP 3: isBatteryPublished -->
    <!-- The battery topic should be published at least each five seconds. -->
    <property id="isBatteryPublished" pattern="recurrence">
      <event>battery_published</event>
      <scope type="globally"/>
      <time_interval time="5" time_unit="s"/>
    </property>
    
    <!-- PROP 4: isPoiSelectionCorrect** -->
    <!-- WARN: tour_complete? -->
    <!-- If the tour is completed, the robot must arrive to the start point within a certain time. -->
    <!-- <property id="isPoiSelectionCorrect" expr="H !({check_start == 1} S[:100] {tour_complete})"/> -->

    <!-- PROP 5: isPeopleFollowingPublished -->
    <!-- The peopleFollowing topic must be published at least each 7 seconds. -->
    <property id="isPeopleFollowingPublished" pattern="recurrence">
      <event>people_following_published</event>
      <scope type="globally"/>
      <time_interval time="7" time_unit="s"/>
    </property>

    <!-- PROP 6: isCameraPublished -->
    <!-- WARN: Cannot find camera -->
    <!-- The camera topic must be published at least each 5 seconds. -->
    <!-- <property id="isCameraPublished" expr="H ((P[50:] true) -> P[:50] { camera_published })"/> -->

    <!-- PROP 7: notCriticalBattery -->
    <!-- WARN: Cannot find critical_battery -->
    <!-- It must never happens that the battery level becomes critical. -->
    <property id="notCriticalBattery1" pattern="universality">
      <event>battery_level &gt; 5</event>
      <scope type="globally"/>
    </property>
    
    <!-- OR -->
    <property id="notCriticalBattery2" pattern="absence">
      <event>battery_level &lt;= 5</event>
      <scope type="globally"/>
    </property>

    <!-- PROP 8: notWheelsHWFault -->
    <!-- WARN: Cannot find weel/joint/control -->
    <!-- The wheels joints must not be in hardware fault. -->

    <!-- PROP 9: notJointsHWFault -->
    <!-- WARN: Cannot find joint/control -->
    <!-- The joints of the robot must not be in hardware fault. -->

    <!-- PROP 10 POI1: isPOICompletedInTime -->
    <!-- WARN: timer only gets up to 100_000ms i.e. 100s (resolution 100ms) -->
    <!-- WARN: poi_selected is never 1 -->
    <!-- If a POI is completed, than it must have been set to selected before. -->
    <!-- Moreover, if a POI is selected then it must be completed within 10 minutes (600 seconds). -->
    <!-- <property id="isPOI1CompletedInTime" expr="H (({poi1_completed == 0} -> P{poi_selected == 1}) and not( {poi1_completed != 0} S[6000:] {poi_selected == 1}))"/> -->
    <!-- <property id="neverPOI" expr="H{poi_selected == 0}"/> -->

    <!-- PROP 11: isWellLocalized -->
    <!-- WARN: cannot find localized/acml -->
    <!-- The robot must be well localized: i.e. the covariance provided by amcl must be lower than or equal to a certain threshold. -->

    <!-- PROP 12: isMicrophonePluggedIn -->
    <!-- WARN: cannot find microphone -->
    <!-- If the microphone is plugged in then the covariance of the audio’s output, when the microphone is recording, should be greater than a certain threshold. -->

    <!-- PROP 13: isExternalPCConnected -->
    <!-- The laptop used for launching the tour should be connected. -->
    <property id="isExternalPCConnected" pattern="recurrence">
      <event>connected_to_network</event>
      <scope type="globally"/>
      <time_interval time="3" time_unit="s"/>
    </property>

    <!-- PROP 14: isConnectedToWeb -->
    <!-- WARN: cannot find web -->
    <!-- The laptop or R1 base should always be connected to the web. -->

    <!-- PROP 15: isArrivedAtChargingStationInTime** -->
    <!-- WARN: never gets to charging station -->
    <!-- When the battery is low it should arrive to the charging station within a certain amount of time. -->
    <property id="isArrivedAtChargingStationInTime" pattern="response">
      <events>
        <event>battery_low_alarm</event>
        <event>is_at_charging_station == 0</event>
      </events>
      <scope type="globally"/>
      <time_interval time="60" time_unit="s"/>
    </property>

  </guarantees>

</properties>
