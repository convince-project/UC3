<?xml version="1.0" encoding="UTF-8"?>
<scxml
  xmlns="http://www.w3.org/2005/07/scxml"
  version="1.0"
  name="PlanSkill"
  datamodel="ecmascript"
  initial="idle">

  <datamodel>
    <data id="m_is_ok" type="bool" expr="false"/>
    <data id="SKILL_SUCCESS"        type="int8"   expr="0"/>
    <data id="SKILL_FAILURE"        type="int8"   expr="1"/>
  </datamodel>

  <!-- Condition skill: tick server only -->
  <ros_service_server service_name="/PlanSkill/tick" type="bt_interfaces_dummy/TickCondition"/>

  <!-- Client for AllowedToMoveComponent.IsAllowedToMove -->
  <ros_service_client service_name="/PlannerComponent/Plan" type="planner_interfaces/srv/Plan"/>

  <state id="idle">
    <!-- this is a mockup, should be replaced with actual service call -->
    <ros_service_handle_request name="/PlanSkill/tick" target="idle">
        <ros_service_send_response name="/PlanSkill/tick">
          <field name="status" expr="SKILL_SUCCESS"/>
          <field name="is_ok" expr="true"/>
        </ros_service_send_response>
      <!-- <ros_service_send_request name="/PlannerComponent/Plan"/> -->
    </ros_service_handle_request>
  </state>

  <state id="query">
    <ros_service_handle_response name="/PlannerComponent/Plan" target="decide">
      <assign location="m_is_ok" expr="_res.is_ok"/>
    </ros_service_handle_response>
  </state>

  <state id="decide">
    <onentry>
      <if cond="m_is_ok">
        <ros_service_send_response name="/PlanSkill/tick">
          <field name="status" expr="SKILL_SUCCESS"/>
          <field name="is_ok" expr="true"/>
        </ros_service_send_response>
      <else/>
        <ros_service_send_response name="/PlanSkill/tick">
          <field name="status" expr="SKILL_FAILURE"/>
          <field name="is_ok" expr="true"/>
        </ros_service_send_response>
      </if>
    </onentry>
    <transition target="idle"/>
  </state>

</scxml>